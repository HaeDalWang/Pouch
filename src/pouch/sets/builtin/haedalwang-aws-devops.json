{
  "name": "haedalwang-aws-devops",
  "title": "해달왕의 AWS DevOps 엔지니어 세트",
  "description": "AWS 위에서 인프라를 돌보는 사람의 기본 한 벌 — 권한(IAM), 코드형 인프라(CDK·CloudFormation), 컨테이너, 관측, 비용, 서버리스.",
  "match": ["devops", "aws", "sre", "infra", "infrastructure", "cloud", "kubernetes", "k8s"],
  "items": [
    {
      "source": "~/.claude/plugins/cache/agent-toolkit-for-aws",
      "install": [
        "aws-iam",
        "aws-cdk",
        "aws-cloudformation",
        "aws-containers",
        "aws-observability",
        "aws-billing-and-cost-management",
        "aws-serverless"
      ]
    }
  ]
}
